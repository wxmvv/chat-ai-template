{
	"useTabs": true,
	"tabWidth": 4,
	"printWidth": 100,
	"endOfLine": "auto",
	"trailingComma": "none",
	"htmlWhitespaceSensitivity": "ignore",
	"semi": true,
	"singleQuote": true,
	"jsxSingleQuote": false,
	"overrides": [
		{
			"files": ["*.md", "*.mdx"],
			"options": {
				"useTabs": false,
				"tabWidth": 2,
				"singleQuote": false
			}
		}
	]
}
